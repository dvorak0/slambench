FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && \
    apt-get install -y --no-install-recommends \
      build-essential \
      ninja-build \
      git \
      python3 \
      python3-pip \
      python3-dev \
      libtinfo-dev \
      zlib1g-dev \
      libxml2-dev \
      libcurl4-openssl-dev \
      libedit-dev \
      curl \
      wget \
      xz-utils \
      ca-certificates && \
    rm -rf /var/lib/apt/lists/*

# Halide currently requires CMake >= 3.28
RUN python3 -m pip install --no-cache-dir "cmake>=3.28"

# Install LLVM 21 from official prebuilt tarball instead of apt.llvm.org packages.
RUN mkdir -p /opt/llvm-21 && \
    wget -O /tmp/llvm21.tar.xz https://github.com/llvm/llvm-project/releases/download/llvmorg-21.1.8/LLVM-21.1.8-Linux-X64.tar.xz && \
    tar -xf /tmp/llvm21.tar.xz -C /opt/llvm-21 --strip-components=1 && \
    rm -f /tmp/llvm21.tar.xz

ENV PATH=/opt/llvm-21/bin:$PATH \
    LD_LIBRARY_PATH=/opt/llvm-21/lib:$LD_LIBRARY_PATH \
    CC=clang \
    CXX=clang++ \
    LLVM_DIR=/opt/llvm-21/lib/cmake/llvm \
    Clang_DIR=/opt/llvm-21/lib/cmake/clang \
    LLD_DIR=/opt/llvm-21/lib/cmake/lld

WORKDIR /opt/halide
COPY third_party/Halide/ /opt/halide/

RUN cmake -S . -B build -G Ninja -DCMAKE_BUILD_TYPE=Release && \
    cmake --build build -j1

RUN test -f /opt/halide/build/src/Halide.h || test -f /opt/halide/include/Halide.h
RUN find /opt/halide/build -name 'libHalide.so*' -o -name 'libHalide.a' | tee /tmp/halide_libs.txt && test -s /tmp/halide_libs.txt
RUN find /opt/halide/build -name '*autoschedule*' | tee /tmp/autoschedulers.txt && test -s /tmp/autoschedulers.txt

WORKDIR /workspace
CMD ["bash"]
