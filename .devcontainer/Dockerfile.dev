FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && \
    apt-get install -y --no-install-recommends \
      build-essential \
      ninja-build \
      git \
      python3 \
      python3-pip \
      python3-dev \
      libtinfo-dev \
      zlib1g-dev \
      libxml2-dev \
      libcurl4-openssl-dev \
      libedit-dev \
      flatbuffers-compiler \
      libflatbuffers-dev \
      curl \
      ca-certificates \
      gnupg \
      lsb-release \
      software-properties-common \
      wget \
      xz-utils && \
    rm -rf /var/lib/apt/lists/*

# Halide currently requires CMake >= 3.28
RUN python3 -m pip install --no-cache-dir "cmake>=3.28"

# Install LLVM/Clang/LLD 21 from apt.llvm.org.
RUN bash -lc 'set -euo pipefail; \
    mkdir -p /etc/apt/keyrings; \
    curl -fsSL https://apt.llvm.org/llvm-snapshot.gpg.key | gpg --dearmor -o /etc/apt/keyrings/llvm.gpg; \
    echo "deb [signed-by=/etc/apt/keyrings/llvm.gpg] http://apt.llvm.org/jammy/ llvm-toolchain-jammy-21 main" > /etc/apt/sources.list.d/llvm.list; \
    printf "Acquire::Retries \"10\";\nAcquire::http::Timeout \"30\";\nAcquire::https::Timeout \"30\";\n" > /etc/apt/apt.conf.d/80-retries; \
    apt-get update; \
    apt-get install -y --fix-missing --no-install-recommends \
      llvm-21 llvm-21-dev \
      clang-21 libclang-21-dev \
      lld-21 liblld-21-dev'

ENV CC=clang-21 \
    CXX=clang++-21 \
    LLVM_DIR=/usr/lib/llvm-21/lib/cmake/llvm \
    Clang_DIR=/usr/lib/llvm-21/lib/cmake/clang \
    LLD_DIR=/usr/lib/llvm-21/lib/cmake/lld

WORKDIR /opt/halide
COPY third_party/Halide/ /opt/halide/

RUN cmake -S . -B build -G Ninja -DCMAKE_BUILD_TYPE=Release && \
    cmake --build build -j1

RUN test -f /opt/halide/build/src/Halide.h || test -f /opt/halide/include/Halide.h
RUN find /opt/halide/build -name 'libHalide.so*' -o -name 'libHalide.a' | tee /tmp/halide_libs.txt && test -s /tmp/halide_libs.txt
RUN find /opt/halide/build -name '*autoschedule*' | tee /tmp/autoschedulers.txt && test -s /tmp/autoschedulers.txt

WORKDIR /workspace
CMD ["bash"]
